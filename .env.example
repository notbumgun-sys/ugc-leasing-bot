# Токен бота от @BotFather
BOT_TOKEN=

# ID админов через запятую (кому слать уведомления о заявках).
# Свой ID можно узнать у @userinfobot
ADMIN_IDS=

# ID Google Sheet — берётся из URL таблицы:
# https://docs.google.com/spreadsheets/d/<ЭТО_ID>/edit
SHEET_ID=

# Путь к JSON-файлу service account из Google Cloud
GOOGLE_CREDS_FILE=credentials.json
